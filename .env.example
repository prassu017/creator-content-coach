# Creator Content Coach - Environment Variables
# Copy this file to .env.local and fill in your values

# OpenAI API Key (only needed for Live Mode)
# Leave empty to use Demo Mode with deterministic mock outputs
OPENAI_API_KEY=sk-your-openai-api-key-here

# Mode: "demo" or "live"
# demo = no external API calls, uses mock data
# live = uses OpenAI API for real analysis
NEXT_PUBLIC_DEFAULT_MODE=demo

# Supabase (optional - enables persistent history and live analytics)
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
